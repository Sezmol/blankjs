{
  "name": "@blankjs/core",
  "version": "0.1.0",
  "description": "Headless form primitives",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsdown": "^0.22.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sezmol/blankjs.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Sezmol/blankjs#readme",
  "bugs": "https://github.com/Sezmol/blankjs/issues",
  "author": "Sezmol",
  "keywords": [
    "react",
    "ui",
    "headless",
    "components",
    "form",
    "accessible"
  ]
}
