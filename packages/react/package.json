{
  "name": "@blankjs/react",
  "version": "0.1.1",
  "description": "Form-first React components",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./styles.css": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@blankjs/core": "workspace:*",
    "@floating-ui/react": "^0.27.19"
  },
  "peerDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@blankjs/tokens": "workspace:*",
    "@tsdown/css": "^0.22.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sezmol/blankjs.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Sezmol/blankjs#readme",
  "bugs": "https://github.com/Sezmol/blankjs/issues",
  "author": "Sezmol",
  "keywords": [
    "react",
    "ui",
    "headless",
    "components",
    "form",
    "accessible"
  ]
}
