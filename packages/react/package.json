{
  "name": "@blankjs/react",
  "version": "0.0.0",
  "description": "Form-first React components",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "lint": "eslint src"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@blankjs/core": "workspace:*",
    "@blankjs/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.2"
  }
}
